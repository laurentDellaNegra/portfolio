---
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.slice(1);
const isPerso = currentPath.includes("perso");
---

<div
  class="mx-auto flex w-fit justify-center gap-5 rounded-lg border border-neon-cyan/20 p-1 text-xs sm:text-base"
>
  <div class={`glow-wrapper ${!isPerso ? "active" : ""}`}>
    <a
      href="/#article"
      class={`glow-btn block px-3 py-2 rounded-md font-semibold sm:w-40 text-center transition-all duration-300 ${
        !isPerso
          ? "neon-text-cyan"
          : "text-gray-500 hover:text-neon-cyan/60"
      }`}
    >
      Work
    </a>
  </div>
  <div class={`glow-wrapper ${isPerso ? "active" : ""}`}>
    <a
      href="/perso#article"
      class={`glow-btn block px-3 py-2 rounded-md font-semibold sm:w-40 text-center transition-all duration-300 ${
        isPerso
          ? "neon-text-cyan"
          : "text-gray-500 hover:text-neon-cyan/60"
      }`}
    >
      Personal projects
    </a>
  </div>
</div>

<style>
  @property --angle {
    syntax: "<angle>";
    initial-value: 0deg;
    inherits: false;
  }

  .glow-wrapper {
    position: relative;
    border-radius: 0.375rem;
  }

  .glow-wrapper.active .glow-btn {
    background:
      linear-gradient(rgb(3, 7, 18), rgb(3, 7, 18)) padding-box,
      conic-gradient(
        from var(--angle),
        transparent 25%,
        #00f0ff 35%,
        #b000ff 45%,
        transparent 55%
      ) border-box;
    border: 2px solid transparent;
    box-shadow:
      0 0 8px rgba(0, 240, 255, 0.4),
      0 0 20px rgba(0, 240, 255, 0.25),
      0 0 40px rgba(0, 240, 255, 0.15),
      0 0 80px rgba(0, 240, 255, 0.08);
    animation: rotate-border 4s linear infinite;
  }

  /* Outer glow aura */
  .glow-wrapper.active::before {
    content: "";
    position: absolute;
    inset: -8px;
    border-radius: 0.75rem;
    background: conic-gradient(
      from var(--angle),
      transparent 25%,
      rgba(0, 240, 255, 0.2) 35%,
      rgba(176, 0, 255, 0.15) 45%,
      transparent 55%
    );
    filter: blur(14px);
    z-index: -1;
    animation: rotate-border 4s linear infinite;
    pointer-events: none;
  }

  @keyframes rotate-border {
    to {
      --angle: 360deg;
    }
  }
</style>
