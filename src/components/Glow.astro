---
import AnimatedStars from "./AnimatedStars";
const id = crypto.randomUUID();
---

<div
  class="absolute inset-0 -z-10 overflow-hidden bg-gray-950 lg:right-[calc(max(2rem,50%-38rem)+40rem)] lg:min-w-[32rem]"
>
  <AnimatedStars client:only />
  <svg
    class="absolute -bottom-48 left-[-40%] h-[80rem] w-[180%] lg:-right-40 lg:bottom-auto lg:left-auto lg:top-[-40%] lg:h-[180%] lg:w-[80rem]"
    aria-hidden="true"
  >
    <defs>
      <radialGradient id={`${id}-desktop`} cx="100%">
        <stop offset="0%" stop-color="rgba(0, 240, 255, 0.25)"></stop>
        <stop offset="35%" stop-color="rgba(176, 0, 255, 0.1)"></stop>
        <stop offset="65%" stop-color="rgba(255, 0, 229, 0.05)"></stop>
        <stop offset="100%" stop-color="rgba(10, 10, 20, 0)"></stop>
      </radialGradient>
      <radialGradient id={`${id}-mobile`} cy="100%">
        <stop offset="0%" stop-color="rgba(0, 240, 255, 0.25)"></stop>
        <stop offset="35%" stop-color="rgba(176, 0, 255, 0.1)"></stop>
        <stop offset="65%" stop-color="rgba(255, 0, 229, 0.05)"></stop>
        <stop offset="100%" stop-color="rgba(10, 10, 20, 0)"></stop>
      </radialGradient>
    </defs>
    <rect
      width="100%"
      height="100%"
      fill={`url(#${id}-desktop)`}
      class="hidden lg:block"></rect>
    <rect
      width="100%"
      height="100%"
      fill={`url(#${id}-mobile)`}
      class="lg:hidden"></rect>
  </svg>
  <div
    class="absolute inset-x-0 bottom-0 right-0 h-px bg-neon-cyan/30 shadow-neon-cyan lg:left-auto lg:top-0 lg:h-auto lg:w-px"
  >
  </div>
</div>
